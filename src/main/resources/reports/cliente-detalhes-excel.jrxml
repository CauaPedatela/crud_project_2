<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="cliente_detalhes_excel" pageWidth="800" pageHeight="842" columnWidth="800" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d">

    <property name="net.sf.jasperreports.export.xls.detect.cell.type" value="true"/>
    <property name="net.sf.jasperreports.export.xls.remove.empty.space.between.rows" value="true"/>
    <property name="net.sf.jasperreports.export.xls.remove.empty.space.between.columns" value="true"/>
    <property name="net.sf.jasperreports.export.xls.white.page.background" value="false"/>

    <parameter name="ID_CLIENTE" class="java.lang.Long"/>

    <queryString language="SQL">
        <![CDATA[SELECT
            c.id AS cliente_id, c.nome, c.email, c.cpf_cnpj, c.rg_inscricao_estadual,
            c.tipo_pessoa, c.data_nascimento, c.data_cadastro, c.telefone, c.ativo,
            e.id AS endereco_id, e.logradouro, e.numero, e.complemento, e.bairro,
            e.cidade, e.estado, e.cep, e.pais, e.principal, e.tipo
        FROM tb_cliente c
        LEFT JOIN tb_endereco e ON c.id = e.cliente_id
        WHERE c.id = $P{ID_CLIENTE}]]>
    </queryString>

    <field name="cliente_id" class="java.lang.Long"/>
    <field name="nome" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="cpf_cnpj" class="java.lang.String"/>
    <field name="rg_inscricao_estadual" class="java.lang.String"/>
    <field name="tipo_pessoa" class="java.lang.String"/>
    <field name="data_nascimento" class="java.sql.Date"/>
    <field name="data_cadastro" class="java.sql.Date"/>
    <field name="telefone" class="java.lang.String"/>
    <field name="ativo" class="java.lang.Boolean"/>

    <field name="endereco_id" class="java.lang.Long"/>
    <field name="logradouro" class="java.lang.String"/>
    <field name="numero" class="java.lang.String"/>
    <field name="complemento" class="java.lang.String"/>
    <field name="bairro" class="java.lang.String"/>
    <field name="cidade" class="java.lang.String"/>
    <field name="estado" class="java.lang.String"/>
    <field name="cep" class="java.lang.String"/>
    <field name="pais" class="java.lang.String"/>
    <field name="principal" class="java.lang.Boolean"/>
    <field name="tipo" class="java.lang.String"/>

    <title>
        <band height="200">
            <staticText><reportElement mode="Opaque" x="0" y="0" width="800" height="20" backcolor="#006699" forecolor="#FFFFFF" uuid="99999999-9999-9999-9999-999999999001"/><textElement verticalAlignment="Middle"><font size="12" isBold="true"/></textElement><text><![CDATA[ DADOS DO CLIENTE]]></text></staticText>

            <staticText><reportElement mode="Opaque" x="0" y="20" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999002"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ Nome / Razão Social]]></text></staticText>
            <textField><reportElement x="150" y="20" width="650" height="20" uuid="99999999-9999-9999-9999-999999999003"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="40" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999004"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ E-mail]]></text></staticText>
            <textField><reportElement x="150" y="40" width="650" height="20" uuid="99999999-9999-9999-9999-999999999005"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{email}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="60" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999006"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ CPF / CNPJ]]></text></staticText>
            <textField><reportElement x="150" y="60" width="650" height="20" uuid="99999999-9999-9999-9999-999999999007"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{cpf_cnpj}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="80" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999008"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ RG / Inscrição Est.]]></text></staticText>
            <textField><reportElement x="150" y="80" width="650" height="20" uuid="99999999-9999-9999-9999-999999999009"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{rg_inscricao_estadual} != null ? $F{rg_inscricao_estadual} : "Não informado"]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="100" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999010"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ Tipo de Pessoa]]></text></staticText>
            <textField><reportElement x="150" y="100" width="650" height="20" uuid="99999999-9999-9999-9999-999999999011"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{tipo_pessoa}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="120" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999012"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ Nasc. / Fundação]]></text></staticText>
            <textField pattern="dd/MM/yyyy"><reportElement x="150" y="120" width="650" height="20" uuid="99999999-9999-9999-9999-999999999013"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[("Física".equalsIgnoreCase($F{tipo_pessoa}) || "PF".equalsIgnoreCase($F{tipo_pessoa})) ? $F{data_nascimento} : $F{data_cadastro}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="140" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999014"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ Telefone]]></text></staticText>
            <textField><reportElement x="150" y="140" width="650" height="20" uuid="99999999-9999-9999-9999-999999999015"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[$F{telefone}]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="160" width="150" height="20" backcolor="#E6E6E6" uuid="99999999-9999-9999-9999-999999999016"/><textElement verticalAlignment="Middle"><font isBold="true"/></textElement><text><![CDATA[ Ativo]]></text></staticText>
            <textField><reportElement x="150" y="160" width="650" height="20" uuid="99999999-9999-9999-9999-999999999017"/><textElement verticalAlignment="Middle"/><textFieldExpression><![CDATA[($F{ativo} != null && $F{ativo}) ? "Sim" : "Não"]]></textFieldExpression></textField>

            <staticText><reportElement mode="Opaque" x="0" y="180" width="800" height="20" backcolor="#006699" forecolor="#FFFFFF" uuid="99999999-9999-9999-9999-999999999018"/><textElement verticalAlignment="Middle"><font size="12" isBold="true"/></textElement><text><![CDATA[ LISTA DE ENDEREÇOS]]></text></staticText>
        </band>
    </title>

