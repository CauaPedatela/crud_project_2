<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="cliente_detalhes" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d">
    <property name="com.jaspersoft.studio.data.sql.tables" value=""/>
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="DataAdapter.jrdax"/>

    <parameter name="ID_CLIENTE" class="java.lang.Long"/>

    <queryString language="SQL">
        <![CDATA[SELECT
            c.id AS cliente_id, c.nome, c.email, c.cpf_cnpj, c.rg_inscricao_estadual,
            c.tipo_pessoa, c.data_nascimento, c.data_cadastro, c.telefone, c.ativo,
            e.id AS endereco_id, e.logradouro, e.numero, e.complemento, e.bairro,
            e.cidade, e.estado, e.cep, e.pais, e.principal, e.tipo
        FROM tb_cliente c
        LEFT JOIN tb_endereco e ON c.id = e.cliente_id
        WHERE c.id = $P{ID_CLIENTE}]]>
    </queryString>

    <field name="cliente_id" class="java.lang.Long"/>
    <field name="nome" class="java.lang.String"/>
    <field name="email" class="java.lang.String"/>
    <field name="cpf_cnpj" class="java.lang.String"/>
    <field name="rg_inscricao_estadual" class="java.lang.String"/>
    <field name="tipo_pessoa" class="java.lang.String"/>
    <field name="data_nascimento" class="java.sql.Date"/>
    <field name="data_cadastro" class="java.sql.Date"/>
    <field name="telefone" class="java.lang.String"/>
    <field name="ativo" class="java.lang.Boolean"/>

    <field name="endereco_id" class="java.lang.Long"/>
    <field name="logradouro" class="java.lang.String"/>
    <field name="numero" class="java.lang.String"/>
    <field name="complemento" class="java.lang.String"/>
    <field name="bairro" class="java.lang.String"/>
    <field name="cidade" class="java.lang.String"/>
    <field name="estado" class="java.lang.String"/>
    <field name="cep" class="java.lang.String"/>
    <field name="pais" class="java.lang.String"/>
    <field name="principal" class="java.lang.Boolean"/>
    <field name="tipo" class="java.lang.String"/>

    <background>
        <band/>
    </background>

    <title>
        <band height="250">
            <frame>
                <reportElement mode="Opaque" x="-20" y="-20" width="595" height="92" backcolor="#006699" uuid="568ac94b-3f21-4bc3-bbeb-e1a728de11f6"/>
                <textField textAdjust="StretchHeight">
                    <reportElement x="20" y="20" width="380" height="43" forecolor="#FFFFFF" uuid="1bdd5756-a663-4f84-a60b-4ff02872bf97"/>
                    <textElement>
                        <font size="26" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{nome} != null ? $F{nome}.toUpperCase() : "CLIENTE NÃO ENCONTRADO"]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="410" y="43" width="165" height="20" forecolor="#FFFFFF" uuid="7634d01c-e3c1-4167-b33a-1880b39463ef"/>
                    <textElement textAlignment="Right">
                        <font size="14" isBold="false"/>
                    </textElement>
                    <textFieldExpression><![CDATA["ID DO CLIENTE: " + $F{cliente_id}]]></textFieldExpression>
                </textField>
            </frame>

            <staticText>
                <reportElement x="0" y="80" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111111"><property name="com.jaspersoft.studio.unit.height" value="px"/></reportElement>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Nome:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="80" width="405" height="20" uuid="11111111-1111-1111-1111-111111111112"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="100" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111113"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Email:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="100" width="405" height="20" uuid="11111111-1111-1111-1111-111111111114"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$F{email} != null ? $F{email} : "Não informado"]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="120" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111115"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[CPF ou CNPJ:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="120" width="405" height="20" uuid="11111111-1111-1111-1111-111111111116"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$F{cpf_cnpj}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="140" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111117"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[RG ou Inscrição Est.:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="140" width="405" height="20" uuid="11111111-1111-1111-1111-111111111118"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$F{rg_inscricao_estadual} != null ? $F{rg_inscricao_estadual} : "Isento/Não informado"]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="160" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111119"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Tipo Pessoa:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="160" width="405" height="20" uuid="11111111-1111-1111-1111-111111111120"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[$F{tipo_pessoa}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="180" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111121"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Nascimento/Fundação:]]></text>
            </staticText>
            <textField pattern="dd/MM/yyyy">
                <reportElement x="150" y="180" width="405" height="20" uuid="11111111-1111-1111-1111-111111111122"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[("Física".equalsIgnoreCase($F{tipo_pessoa}) || "PF".equalsIgnoreCase($F{tipo_pessoa})) ? $F{data_nascimento} : $F{data_cadastro}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="200" width="150" height="20" forecolor="#006699" uuid="11111111-1111-1111-1111-111111111123"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <text><![CDATA[Ativo no Sistema:]]></text>
            </staticText>
            <textField>
                <reportElement x="150" y="200" width="405" height="20" uuid="11111111-1111-1111-1111-111111111124"/>
                <textElement><font size="12"/></textElement>
                <textFieldExpression><![CDATA[($F{ativo} != null && $F{ativo}) ? "Sim" : "Não"]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="230" width="555" height="20" forecolor="#333333" uuid="11111111-1111-1111-1111-111111111125"/>
                <textElement textAlignment="Center"><font size="14" isBold="true"/></textElement>
                <text><![CDATA[LISTA DE ENDEREÇOS VINCULADOS]]></text>
            </staticText>
        </band>
    </title>

