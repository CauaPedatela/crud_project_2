# Copie esse arquivo, renomeie para "application.properties" e preencha com seus dados locais.
# NUNCA renomeie o application.properties.example — ele deve permanecer no GitHub como guia.

# =============================================
# Configurações de conexão com o banco MySQL
# =============================================
spring.datasource.url=jdbc:mysql://localhost:3306/crud_project_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Sao_Paulo
spring.datasource.username=root
spring.datasource.password=SUA_SENHA_AQUI
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# =============================================
# Configurações do Hibernate (JPA)
# =============================================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# =============================================
# Configurações do servidor
# =============================================
server.port=8080
